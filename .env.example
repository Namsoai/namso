# =============================================================================
# AI Task Connect (Namso) — Environment Variable Reference
# Copy this file to .env.local for local development.
# NEVER commit actual secret values to version control.
# =============================================================================

# ── Frontend (Vite — bundled into JS bundle, safe public values) ──────────────
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key-here

# ── Edge Function Secrets (set via: supabase secrets set KEY=value) ───────────
# These are NEVER exposed to the browser. Supabase injects them at runtime.

# Escrow.com API credentials
ESCROW_API_KEY=your-escrow-api-key-here
ESCROW_PLATFORM_EMAIL=platform@yourdomain.com

# Escrow.com base URL — MUST switch to production URL before go-live:
#   Sandbox:    https://api.escrow-sandbox.com/2017-09-01
#   Production: https://api.escrow.com/2017-09-01
ESCROW_API_BASE_URL=https://api.escrow.com/2017-09-01

# Email sending (Resend)
RESEND_API_KEY=your-resend-api-key-here

# CORS — restrict edge function origin in production
ALLOWED_ORIGIN=https://yourdomain.com

# ── Auto-injected by Supabase Edge Function runtime (do NOT set manually) ─────
# SUPABASE_URL             → same as VITE_SUPABASE_URL
# SUPABASE_SERVICE_ROLE_KEY → admin key — server-only, NEVER expose to browser
# SUPABASE_ANON_KEY        → same as VITE_SUPABASE_ANON_KEY

